<tr class="worker">
  <td>
    <%= link_to "worker #{worker.id}", application_worker_path(@application, worker.id) %>
    <br />
    <%= worker.name %>
  </td>
  <td><%= worker.hostname %></td>
  <td>
    <% worker.jobs.each do |job| %>
      <div>
        <%= link_to job_title(job), application_job_path(@application, job.job_id) %>

        <% if job.serialized_arguments.present? %>
          <div class="is-family-monospace is-size-7"><%= job_arguments(job) %></div>
        <% end %>
      </div>
    <% end %>
  </td>

  <td><div class="has-text-grey"><%= time_distance_in_words_with_title(worker.last_heartbeat_at) %> ago</div></td>
  <td>
    <div class="buttons is-right">
      <%= button_to "Kill", prune_application_worker_path(@application, worker.id), method: :post, class: "button is-danger is-light is-small mr-0",
        form: { data: { turbo_confirm: "This will kill the worker process and move its in-progress jobs to failed. Are you sure?" } } %>
    </div>
  </td>
</tr>
